{
  "manifest_version": 3,
  "name": "All-in-One Link Bypasser",
  "version": "1.0",
  "description": "Browser extension to automatically bypass safelinks and annoying ads.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
